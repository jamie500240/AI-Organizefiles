# =============================================================================
# [SET] 領域層：全域系統設定 (Immutable Configuration)
# =============================================================================
@dataclass(frozen=True)
class cls_AppConfig:
    # 核心參數
    BUFFER_SIZE: int = 1024 * 1024        # 檔案讀取緩衝區大小 (1MB)
    HASH_LENGTH: int = 16                 # SHA-256 截斷長度
    ESTIMATE_MB_PER_SEC: float = 50.0     # DRY RUN 預估速度 (MB/s)
    SAFE_SPACE_RATIO: float = 1.1         # 安全磁碟空間倍率 (需求空間的 1.1 倍)
    
    # 資料夾命名合約
    DIR_TEMP: str = "0_Temp_Sandbox"          # 沙盒區 (ACDS P0 規範)
    DIR_UNIQUE: str = "1_Unique_Archive"      # 歸檔區：唯一檔案
    DIR_DUPLICATE: str = "2_Duplicates_Iso"   # 歸檔區：重複檔案隔離
    DIR_FAILED: str = "3_Failed_Items"        # 異常處理區
    REPORT_FILENAME: str = "Process_Report.csv"
    
    # 功能開關 (Toggleable Features)
    ENABLE_FILENAME_RESTORE: bool = True  # Phase 2a: 是否移除 Unique 區 Hash 標記
    ENABLE_DIR_FLATTENING: bool = True    # Phase 2b: 是否執行隧道坍塌 (目錄扁平化)
    MIN_ITEMS_FOR_DIR: int = 2            # 隧道坍塌門檻：少於 2 個項目即拆除資料夾

CONFIG = cls_AppConfig()

# =============================================================================
